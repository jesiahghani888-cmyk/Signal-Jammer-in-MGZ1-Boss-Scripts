function void SignalJammer.MGZ1.SpecialAttack_SignalBlast()
{
    // A powerful blast that affects the player's controls temporarily
    if (SignalJammer.MGZ1.state == 3 && SignalJammer.MGZ1.stateTimer == 30)
    {
        playSound(0x73) // Signal blast sound
        // Effect logic: apply control override to player
        A1 = 0xffffb000
        objA1.control_override = 0x3c // 60 frames of control loss
    }
}

function void SignalJammer.MGZ1.SpecialAttack_DroneSwarm()
{
    // Rapidly spawn multiple drones for a short period
    if (SignalJammer.MGZ1.state == 3 && SignalJammer.MGZ1.stateTimer > 60 && SignalJammer.MGZ1.stateTimer < 120)
    {
        if (SignalJammer.MGZ1.stateTimer % 20 == 0)
        {
            SignalJammer.MGZ1.SpawnDrones()
        }
    }
}

