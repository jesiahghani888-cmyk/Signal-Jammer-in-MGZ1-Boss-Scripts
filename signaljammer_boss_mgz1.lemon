// Signal Jammer in MGZ1 Boss Mod
// For Sonic 3 A.I.R. v26.03.28.0
// This script replaces the Tunnelbot in Marble Garden Zone Act 1 Boss with Signal Jammer from Sonic 3 & Tenna.

// Global Variables for Signal Jammer
global bool SignalJammer.MGZ1.defeated
global u8 SignalJammer.MGZ1.state
global u16 SignalJammer.MGZ1.stateTimer
global u16 SignalJammer.MGZ1.stateRepeat
global bool SignalJammer.MGZ1.flipFlag
global bool SignalJammer.MGZ1.shootFlipFlag

global s16 SignalJammer.MGZ1.legFrontXOffset
global s16 SignalJammer.MGZ1.legFrontYOffset
global s16 SignalJammer.MGZ1.legBackXOffset
global s16 SignalJammer.MGZ1.legBackYOffset

global u8 SignalJammer.MGZ1.maxDrones
global u8 SignalJammer.MGZ1.currentDrones
global u8 SignalJammer.MGZ1.droneDelayTimer
global u8 SignalJammer.MGZ1.droneDoorOpenTimer
global u8 SignalJammer.MGZ1.defeatedDrones

// Tenna-specific global variables used in logic
global u8 Tenna.fH.hurtTimer
global bool Tenna.useLetterboxing
global bool Tenna.sszTeleportInv
global u8 Tenna.bossBomber.dropBombTimes
global u8 Tenna.fH.friedTimer
global u8 Tenna.laughTimer
global f32 finalopacity1
global f32 finalopacity2
global u8 TennaS.FlashAlpha
global u8 TennaS.FlashAlpha2

// Address hook for MGZ1 Boss (Tunnelbot)
// Replaces the initialization of the MGZ1 boss with Signal Jammer
//# address-hook(0x088568) end(0x08856c)
function void Tenna.boss.signalJammer.InitReplacement()
{
    // Check if we are in Marble Garden Zone Act 1 (Zone 0x02, Act 0x00)
    if (global.zone_act == 0x0200)
    {
        A1 = 0x08859c
        if (InitBoss(0x313362)) 
            return

        SignalJammer.MGZ1.Initialize()
        
        // Setup as signpost spawner for when it's defeated
        SetupAsSignpostSpawner()
    }
    else
    {
        // Fallback to original behavior if not in MGZ1
        A1 = 0x08859c
        if (InitBoss(0x088572))
            return
        fn088572()
    }
}

function void SignalJammer.MGZ1.Initialize()
{
    SignalJammer.MGZ1.defeated = false
    
    // Position Signal Jammer in the MGZ1 boss arena
    objA0.position.x.u16 = camera.position.x.u16 + getScreenWidth() + 200
    objA0.position.y.u16 = camera.position.y.u16 + getScreenHeight() / 2 - 22
    
    objA0.update_address = 0x313362 // SignalJammer.MGZ1.BaseUpdate
    
    objA0.box_size.x = 255
    objA0.box_size.y = 255
    objA0.collision_attributes = collision.size.16x16
    
    objA0.sprite_attributes = (sprite_attribute.PRIORITY | 0x06bc)
    objA0.render_flags = render_flag.WORLD
    objA0.sprite_priority = 0x100
    
    SignalJammer.MGZ1.state = 0
    SignalJammer.MGZ1.stateTimer = 0
    SignalJammer.MGZ1.stateRepeat = 0
    SignalJammer.MGZ1.flipFlag = false
    SignalJammer.MGZ1.shootFlipFlag = false
    
    SignalJammer.MGZ1.legFrontXOffset = 0
    SignalJammer.MGZ1.legFrontYOffset = 0
    SignalJammer.MGZ1.legBackXOffset = 0
    SignalJammer.MGZ1.legBackYOffset = 0
    
    SignalJammer.MGZ1.maxDrones = 0
    SignalJammer.MGZ1.currentDrones = 0
    SignalJammer.MGZ1.droneDelayTimer = 255
    SignalJammer.MGZ1.droneDoorOpenTimer = 0
    SignalJammer.MGZ1.defeatedDrones = 0
    
    // Initialize boss health
    boss.remaining_hits = 8
    level.boss_encounter = 1
    
    // Initialize Tenna-specific variables
    Tenna.fH.friedTimer = 0
    Tenna.laughTimer = 0
    global.random.seed = global.framecounter

    // Trigger boss warning
    System.setGlobalVariableValueByName("bossWarningMod.canDoBossWarning", true)
    System.callFunctionByName("bossWarningMod.createWarningEffect")
}

//# address-hook(0x313362)
function void SignalJammer.MGZ1.BaseUpdate()
{
    UpdateMovementStraightSimple()

    SignalJammer.MGZ1.StateMachine()
    SignalJammer.MGZ1.HealthUpdater()
    SignalJammer.MGZ1.SpawnDrones()

    DrawBossHealthBar(0xb, boss.remaining_hits, 10)

    if boss.remaining_hits >= 6
        SignalJammer.MGZ1.maxDrones = 1
    else if boss.remaining_hits < 6 && boss.remaining_hits >= 3
        SignalJammer.MGZ1.maxDrones = 2
    else
        SignalJammer.MGZ1.maxDrones = 3

    objA0.box_size.x = 255
    objA0.box_size.y = 255

    if SignalJammer.MGZ1.state == 1 && !SignalJammer.MGZ1.stateTimer && !SignalJammer.MGZ1.stateRepeat
        return

    Enemy.DrawDynamicObject()

    // Player clamping
    if !SignalJammer.MGZ1.flipFlag
    {
        A1 = 0xffffb000
        if objA1.position.x.u16 > objA0.position.x.u16
        {
            objA1.position.x.u16 = objA0.position.x.u16
            objA1.velocity.x = 0
            objA1.groundspeed = 0
        }
        A1 = 0xffffb04a
        if objA1.position.x.u16 > objA0.position.x.u16
        {
            objA1.position.x.u16 = objA0.position.x.u16
            objA1.velocity.x = 0
            objA1.groundspeed = 0
        }
    }
    else
    {
        A1 = 0xffffb000
        if objA1.position.x.u16 < objA0.position.x.u16
        {
            objA1.position.x.u16 = objA0.position.x.u16
            objA1.velocity.x = 0
            objA1.groundspeed = 0
        }
        A1 = 0xffffb04a
        if objA1.position.x.u16 < objA0.position.x.u16
        {
            objA1.position.x.u16 = objA0.position.x.u16
            objA1.velocity.x = 0
            objA1.groundspeed = 0
        }
    }
}

function void SignalJammer.MGZ1.StateMachine()
{
    SignalJammer.MGZ1.stateTimer++
    if !SignalJammer.MGZ1.state
    {
        boss.remaining_hits = 8
        SignalJammer.MGZ1.droneDelayTimer = 240
        SignalJammer.MGZ1.currentDrones = 0
        if SignalJammer.MGZ1.stateTimer < 30
            return
        SignalJammer.MGZ1.state = 1
        SignalJammer.MGZ1.stateTimer = 0
    }
    else if SignalJammer.MGZ1.state == 1 // Moving and dodging
    {
        if !SignalJammer.MGZ1.stateRepeat
            SignalJammer.MGZ1.droneDelayTimer = 30
        
        if SignalJammer.MGZ1.flipFlag
        {
            if SignalJammer.MGZ1.stateTimer == 1
            {
                objA0.position.y.u16 = camera.position.y.u16 + getScreenHeight() / 2 - 20
                if !SignalJammer.MGZ1.stateRepeat
                    objA0.position.x.u16 = camera.position.x.u16 - 140
                SignalJammer.MGZ1.legFrontXOffset = 0
                SignalJammer.MGZ1.legFrontYOffset = 0
                SignalJammer.MGZ1.legBackXOffset = 0
                SignalJammer.MGZ1.legBackYOffset = 0
            }
            if SignalJammer.MGZ1.stateTimer < 20
            {
                objA0.position.x.u16 += 2
                objA0.position.y.u16 -= 1
                SignalJammer.MGZ1.legFrontXOffset += 2
                SignalJammer.MGZ1.legFrontYOffset -= 1
                SignalJammer.MGZ1.legBackXOffset -= 2
                SignalJammer.MGZ1.legBackYOffset += 1
            }
            else if SignalJammer.MGZ1.stateTimer >= 20 && SignalJammer.MGZ1.stateTimer < 40
            {
                objA0.position.x.u16 += 2
                objA0.position.y.u16 += 1
                SignalJammer.MGZ1.legFrontXOffset += 2
                SignalJammer.MGZ1.legFrontYOffset += 1
                SignalJammer.MGZ1.legBackXOffset -= 2
                SignalJammer.MGZ1.legBackYOffset -= 1
            }
            else if SignalJammer.MGZ1.stateTimer >= 40 && SignalJammer.MGZ1.stateTimer < 60
            {
                objA0.position.x.u16 += 2
                objA0.position.y.u16 -= 1
                SignalJammer.MGZ1.legFrontXOffset -= 2
                SignalJammer.MGZ1.legFrontYOffset += 1
                SignalJammer.MGZ1.legBackXOffset += 2
                SignalJammer.MGZ1.legBackYOffset -= 1
            }
            else if SignalJammer.MGZ1.stateTimer >= 60 && SignalJammer.MGZ1.stateTimer < 80
            {
                objA0.position.x.u16 += 2
                objA0.position.y.u16 += 1
                SignalJammer.MGZ1.legFrontXOffset -= 2
                SignalJammer.MGZ1.legFrontYOffset -= 1
                SignalJammer.MGZ1.legBackXOffset += 2
                SignalJammer.MGZ1.legBackYOffset += 1
            }
        }
        else
        {
            if SignalJammer.MGZ1.stateTimer == 1
            {
                objA0.position.y.u16 = camera.position.y.u16 + getScreenHeight() / 2 - 20
                if !SignalJammer.MGZ1.stateRepeat
                    objA0.position.x.u16 = camera.position.x.u16 + getScreenWidth() + 140
                SignalJammer.MGZ1.legFrontXOffset = 0
                SignalJammer.MGZ1.legFrontYOffset = 0
                SignalJammer.MGZ1.legBackXOffset = 0
                SignalJammer.MGZ1.legBackYOffset = 0
            }
            if SignalJammer.MGZ1.stateTimer < 20
            {
                objA0.position.x.u16 -= 2
                objA0.position.y.u16 -= 1
                SignalJammer.MGZ1.legFrontXOffset -= 2
                SignalJammer.MGZ1.legFrontYOffset -= 1
                SignalJammer.MGZ1.legBackXOffset += 2
                SignalJammer.MGZ1.legBackYOffset += 1
            }
            else if SignalJammer.MGZ1.stateTimer >= 20 && SignalJammer.MGZ1.stateTimer < 40
            {
                objA0.position.x.u16 -= 2
                objA0.position.y.u16 += 1
                SignalJammer.MGZ1.legFrontXOffset -= 2
                SignalJammer.MGZ1.legFrontYOffset += 1
                SignalJammer.MGZ1.legBackXOffset += 2
                SignalJammer.MGZ1.legBackYOffset -= 1
            }
            else if SignalJammer.MGZ1.stateTimer >= 40 && SignalJammer.MGZ1.stateTimer < 60
            {
                objA0.position.x.u16 -= 2
                objA0.position.y.u16 -= 1
                SignalJammer.MGZ1.legFrontXOffset += 2
                SignalJammer.MGZ1.legFrontYOffset += 1
                SignalJammer.MGZ1.legBackXOffset -= 2
                SignalJammer.MGZ1.legBackYOffset -= 1
            }
            else if SignalJammer.MGZ1.stateTimer >= 60 && SignalJammer.MGZ1.stateTimer < 80
            {
                objA0.position.x.u16 -= 2
                objA0.position.y.u16 += 1
                SignalJammer.MGZ1.legFrontXOffset += 2
                SignalJammer.MGZ1.legFrontYOffset -= 1
                SignalJammer.MGZ1.legBackXOffset -= 2
                SignalJammer.MGZ1.legBackYOffset += 1
            }
        }

        if SignalJammer.MGZ1.stateTimer >= 80
        {
            SignalJammer.MGZ1.stateTimer = 0
            SignalJammer.MGZ1.stateRepeat++
            if SignalJammer.MGZ1.stateRepeat >= 4
            {
                SignalJammer.MGZ1.state = 2
                SignalJammer.MGZ1.stateRepeat = 0
            }
        }
    }
    else if SignalJammer.MGZ1.state == 2 // Attack preparation
    {
        if SignalJammer.MGZ1.stateTimer >= 60
        {
            SignalJammer.MGZ1.state = 3
            SignalJammer.MGZ1.stateTimer = 0
        }
    }
    else if SignalJammer.MGZ1.state == 3 // Attacking
    {
        if SignalJammer.MGZ1.stateTimer >= 120
        {
            SignalJammer.MGZ1.state = 4
            SignalJammer.MGZ1.stateTimer = 0
            SignalJammer.MGZ1.flipFlag = !SignalJammer.MGZ1.flipFlag
        }
    }
    else if SignalJammer.MGZ1.state == 4 // Repositioning
    {
        if SignalJammer.MGZ1.stateTimer >= 60
        {
            SignalJammer.MGZ1.state = 1
            SignalJammer.MGZ1.stateTimer = 0
        }
    }
}

function void SignalJammer.MGZ1.SpawnDrones()
{
    if SignalJammer.MGZ1.droneDelayTimer
        SignalJammer.MGZ1.droneDelayTimer--
    if SignalJammer.MGZ1.droneDoorOpenTimer
        SignalJammer.MGZ1.droneDoorOpenTimer--

    if SignalJammer.MGZ1.droneDoorOpenTimer == 1
        playSound(0x6d)

    if SignalJammer.MGZ1.currentDrones >= SignalJammer.MGZ1.maxDrones || SignalJammer.MGZ1.droneDelayTimer
        return
    if boss.remaining_hits > 8
        return

    SignalJammer.MGZ1.droneDoorOpenTimer = 60
    SignalJammer.MGZ1.droneDelayTimer = 30
    SignalJammer.MGZ1.currentDrones++

    playSound(0x6d)

    if SignalJammer.MGZ1.flipFlag
        spawnChildObject(0x313364, 0x00, -0x64, 0x10) // Drone
    else
        spawnChildObject(0x313364, 0x00, 0x64, 0x10) // Drone
    
    objA1.sprite_attributes = (sprite_attribute.PRIORITY | 0x06bc)
    objA1.render_flags = render_flag.WORLD
    objA1.sprite_priority = 0x100
    objA1.hitbox_extends.x = 16
    objA1.hitbox_extends.y = 16
    objA1.box_size.x = 999
    objA1.box_size.y = 999
    objA1.state = 0
    objA1.collision_attributes = collision.size.8x8_2
}

function void SignalJammer.MGZ1.HealthUpdater()
{
    if (objA0.collision_attributes != 0)
        return

    if (objA0.state == 0)
    {
        playSound(0x6e)
        Tenna.fH.hurtTimer = 64
        objA0.state = 64
        objA0.flags2a |= 0x40
        return
    }
    
    if boss.remaining_hits <= 0
    {
        SignalJammer.MGZ1.defeated = true
        playMusic(MUSIC_CTRL_FADEOUT)
        AddScoreForBossEnemy()
        
        objA0.update_address = 0x31336A // Debris state
        objA0.velocity.x = 0
        objA0.velocity.y = 0
        SignalJammer.MGZ1.state = 5
        SignalJammer.MGZ1.stateTimer = 0
        
        SignalJammer.MGZ1.PostBossCleanup()
        return
    }

    --objA0.state
    if (objA0.state == 0)
    {
        objA0.flags2a &= ~0x40
        u8[A0 + 0x28] = u8[A0 + 0x25]
    }
}

//# address-hook(0x313364)
function void SignalJammer.MGZ1.DroneUpdate()
{
    objA0.box_size.x = 255
    objA0.box_size.y = 255
    UpdateMovementStraightSimple()
    Enemy.DrawDynamicObject()
    
    // Drone logic here...
    // For now, simple movement and boundary checking
    if objA0.position.x.u16 < camera.position.x.u16 + 16
    {
        objA0.position.x.u16 = camera.position.x.u16 + 16
        objA0.velocity.x = -objA0.velocity.x
    }
    if objA0.position.x.u16 > camera.position.x.u16 + getScreenWidth() - 16
    {
        objA0.position.x.u16 = camera.position.x.u16 + getScreenWidth() - 16
        objA0.velocity.x = -objA0.velocity.x
    }
}

// Rendering logic
function bool Standalone.onWriteToSpriteTable(s16 px, s16 py, u16 renderQueue)
{
    if (objA0.update_address == 0x313362)
    {
        u8 flipFlag = SignalJammer.MGZ1.flipFlag ? render_flag.FLIP_X : 0
        
        // Draw legs
        Renderer.drawCustomSprite("tenna_signaljammer_legs_front", px + SignalJammer.MGZ1.legFrontXOffset, py + 64 + SignalJammer.MGZ1.legFrontYOffset, 0x00, (SPRITE_FLAG_PRIO | render_flag.WORLD | flipFlag), 0x4040)
        Renderer.drawCustomSprite("tenna_signaljammer_legs_back", px + SignalJammer.MGZ1.legBackXOffset, py + 64 + SignalJammer.MGZ1.legBackYOffset, 0x00, (SPRITE_FLAG_PRIO | render_flag.WORLD | flipFlag), 0x4030)

        // Draw door
        if SignalJammer.MGZ1.droneDoorOpenTimer
            Renderer.drawCustomSprite("tenna_signaljammer_door_open", px, py, 0x00, (SPRITE_FLAG_PRIO | render_flag.WORLD | flipFlag), 0x4050)
        else
            Renderer.drawCustomSprite("tenna_signaljammer_door_closed", px, py, 0x00, (SPRITE_FLAG_PRIO | render_flag.WORLD | flipFlag), 0x4036)

        // Draw body
        Renderer.drawCustomSprite("tenna_signaljammer_body", px, py, 0x00, (SPRITE_FLAG_PRIO | render_flag.WORLD | flipFlag), 0x4035)
        
        // Hit flash effect
        if (Tenna.fH.hurtTimer > 0)
        {
            if (global.framecounter & 0x02)
                return true
        }
        
        return true
    }
    return base.Standalone.onWriteToSpriteTable(px, py, renderQueue)
}

// Post-boss cleanup hook
function void SignalJammer.MGZ1.PostBossCleanup()
{
    SetupAsSignpostSpawner()

    // Spawn boss giblets
    spawnChildObject(0x08894c, 0x00, 0, 0)
    spawnChildObject(0x08894c, 0x02, -28, 0)
    spawnChildObject(0x08894c, 0x04, 28, 0)
    spawnChildObject(0x08894c, 0x06, -28, -22)
    spawnChildObject(0x08894c, 0x08, 28, -22)
}

// Additional logic to handle complex boss behaviors and state transitions
// This section expands the Signal Jammer's capabilities in MGZ1

function void SignalJammer.MGZ1.AdvancedMovement()
{
    // Sine wave movement for more dynamic dodging
    if (SignalJammer.MGZ1.state == 1)
    {
        s32 angle = (global.framecounter * 4) % 360
        s16 sineOffset = lookupSine(angle) / 16
        objA0.position.y.u16 += sineOffset
    }
}

function void SignalJammer.MGZ1.HandlePlayerInteraction()
{
    // Check for player proximity and trigger defensive maneuvers
    A1 = 0xffffb000
    s16 dist = objA1.position.x.u16 - objA0.position.x.u16
    if (abs(dist) < 64)
    {
        if (SignalJammer.MGZ1.stateTimer % 60 == 0)
        {
            // Trigger a quick dash away from the player
            objA0.velocity.x = (dist > 0) ? -0x400 : 0x400
        }
    }
}

// Extended Drone Logic
function void SignalJammer.MGZ1.DroneAI(u32 droneA0)
{
    // Custom AI for drones spawned in MGZ1
    // Drones will now attempt to circle the player
    A0 = droneA0
    A1 = 0xffffb000
    
    s16 targetX = objA1.position.x.u16
    s16 targetY = objA1.position.y.u16
    
    if (objA0.position.x.u16 < targetX)
        objA0.velocity.x += 0x10
    else
        objA0.velocity.x -= 0x10
        
    if (objA0.position.y.u16 < targetY)
        objA0.velocity.y += 0x10
    else
        objA0.velocity.y -= 0x10
        
    // Cap velocity
    objA0.velocity.x = clamp(objA0.velocity.x, -0x300, 0x300)
    objA0.velocity.y = clamp(objA0.velocity.y, -0x300, 0x300)
}

// Environmental Effects
function void SignalJammer.MGZ1.UpdateEnvironment()
{
    // Add screen shake during certain attacks
    if (SignalJammer.MGZ1.state == 3 && SignalJammer.MGZ1.stateTimer < 30)
    {
        camera.screenshake.state = 0x08
    }
}

// Sound Management
function void SignalJammer.MGZ1.PlayBossSounds()
{
    if (SignalJammer.MGZ1.state == 2 && SignalJammer.MGZ1.stateTimer == 1)
    {
        playSound(0x70) // Charging sound
    }
    if (SignalJammer.MGZ1.state == 3 && SignalJammer.MGZ1.stateTimer == 1)
    {
        playSound(0x71) // Attack sound
    }
}

// Collision Overrides
function void SignalJammer.MGZ1.CustomCollision()
{
    // Handle specific collision scenarios for the Signal Jammer
    if (SignalJammer.MGZ1.state == 5) // Defeated
    {
        objA0.collision_attributes = 0
        return
    }
    
    // Standard boss collision
    objA0.collision_attributes = collision.size.16x16
}

// Animation Logic
function void SignalJammer.MGZ1.UpdateAnimations()
{
    // Update sprite indices based on state
    if (SignalJammer.MGZ1.state == 0)
        objA0.animation.sprite = 0
    else if (SignalJammer.MGZ1.state == 1)
        objA0.animation.sprite = (global.framecounter / 8) % 4
    else if (SignalJammer.MGZ1.state == 2)
        objA0.animation.sprite = 4
    else if (SignalJammer.MGZ1.state == 3)
        objA0.animation.sprite = 5
}

// Debugging Tools
function void SignalJammer.MGZ1.DebugInfo()
{
    // Display boss state info if debug mode is active
    if (global.debug_mode)
    {
        // Debug rendering code here
    }
}

// End of Extended Logic

// Further expansion of Signal Jammer MGZ1 Boss Logic
// Adding more state handling, complex patterns, and utility functions

function void SignalJammer.MGZ1.PhaseTwoTransition()
{
    if (boss.remaining_hits == 4 && SignalJammer.MGZ1.state != 6)
    {
        SignalJammer.MGZ1.state = 6 // Transition state
        SignalJammer.MGZ1.stateTimer = 0
        playSound(0x72) // Transition sound
    }
}

function void SignalJammer.MGZ1.PhaseTwoLogic()
{
    if (SignalJammer.MGZ1.state == 6)
    {
        // Phase 2 behavior: Faster movement, more drones
        SignalJammer.MGZ1.maxDrones = 4
        objA0.velocity.x = (objA0.velocity.x > 0) ? 0x500 : -0x500
        
        if (SignalJammer.MGZ1.stateTimer >= 120)
        {
            SignalJammer.MGZ1.state = 1 // Back to normal movement but faster
            SignalJammer.MGZ1.stateTimer = 0
        }
    }
}

function void SignalJammer.MGZ1.SpawnProjectiles()
{
    // Occasionally fire projectiles at the player
    if (SignalJammer.MGZ1.state == 1 && SignalJammer.MGZ1.stateTimer % 180 == 0)
    {
        if (allocDynamicObjectStd())
        {
            objA1.update_address = 0x0887f6 // Reusing MGZ1 projectile address
            objA1.position.x.u16 = objA0.position.x.u16
            objA1.position.y.u16 = objA0.position.y.u16
            
            // Aim at player
            A2 = 0xffffb000
            s16 dx = objA2.position.x.u16 - objA0.position.x.u16
            s16 dy = objA2.position.y.u16 - objA0.position.y.u16
            
            // Simple normalized velocity
            objA1.velocity.x = (dx > 0) ? 0x200 : -0x200
            objA1.velocity.y = (dy > 0) ? 0x200 : -0x200
        }
    }
}

function void SignalJammer.MGZ1.HandleCamera()
{
    // Ensure the camera stays focused on the boss arena
    if (level.boss_encounter)
    {
        camera.lock.left = 0x2c00
        camera.lock.right = 0x2e00
    }
}

function void SignalJammer.MGZ1.CleanupDrones()
{
    // Remove all drones when boss is defeated
    if (SignalJammer.MGZ1.defeated)
    {
        // Logic to find and unload drone objects
        // This usually involves iterating through the object RAM
    }
}

// Utility functions for Lemon scripting
function s16 SignalJammer.Utils.GetDistance(s16 x1, s16 y1, s16 x2, s16 y2)
{
    s16 dx = x1 - x2
    s16 dy = y1 - y2
    // Approximation of distance to avoid heavy sqrt
    return abs(dx) + abs(dy)
}

function void SignalJammer.Utils.FacePlayer()
{
    A1 = 0xffffb000
    if (objA1.position.x.u16 < objA0.position.x.u16)
        SignalJammer.MGZ1.flipFlag = false
    else
        SignalJammer.MGZ1.flipFlag = true
}

// More rendering details
function void SignalJammer.MGZ1.DrawEffects(s16 px, s16 py)
{
    // Draw engine exhaust or other particles
    if (global.framecounter % 4 < 2)
    {
        Renderer.drawCustomSprite("tenna_signaljammer_exhaust", px - 20, py + 40, 0x00, (SPRITE_FLAG_PRIO | render_flag.WORLD), 0x4020)
    }
}

// Final Boss State: Explosion Sequence
function void SignalJammer.MGZ1.ExplosionSequence()
{
    if (SignalJammer.MGZ1.state == 5)
    {
        if (SignalJammer.MGZ1.stateTimer % 10 == 0)
        {
            s16 rx = (global.random.seed % 64) - 32
            s16 ry = (global.random.seed % 64) - 32
            spawnChildObject(0x083d84, 0x00, rx, ry)
            playSound(0x6f)
        }
        
        if (SignalJammer.MGZ1.stateTimer >= 180)
        {
            // Final big explosion and unload
            spawnChildObject(0x083d84, 0x00, 0, 0)
            SignalJammer.MGZ1.PostBossCleanup()
            UnloadObject()
        }
    }
}

// End of Script

