    // Adjust the hitbox based on the current state or animation frame
    if (SignalJammer.MGZ1.state == 3)
    {
        objA0.hitbox_extends.x = 24
        objA0.hitbox_extends.y = 24
    }
    else
    {
        objA0.hitbox_extends.x = 16
