function void SignalJammer.MGZ1.OnHit()
{
    // Logic to execute when the boss is hit
    if (objA0.collision_attributes == 0 && objA0.state == 64)
    {
        // Boss was just hit
        SignalJammer.MGZ1.currentDrones = 0 // Clear drones on hit as a penalty
    }
