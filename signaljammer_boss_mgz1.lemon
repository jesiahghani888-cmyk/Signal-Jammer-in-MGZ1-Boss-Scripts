/*
    Signal Jammer Boss Script for Marble Garden Zone Act 1
    This script is designed to be a drop-in replacement for the Tunnelbot boss.
    It utilizes the Lemon scripting language features available in S3AIR v26.03.28.0.
    
    The boss behavior is divided into several states:
    - State 0: Initialization and entry
    - State 1: Standard movement and dodging
    - State 2: Attack preparation (charging)
    - State 3: Active attack phase
    - State 4: Recovery and repositioning
    - State 5: Defeat and explosion sequence
    - State 6: Phase transition (triggered at 50% health)
*/

function void SignalJammer.MGZ1.DetailedState_0()
{
    // Initialization logic
    // This function is called once when the boss is first spawned
    if (SignalJammer.MGZ1.state == 0)
    {
        // Set initial position off-screen
        objA0.position.x.u16 = camera.position.x.u16 + getScreenWidth() + 100
        objA0.position.y.u16 = camera.position.y.u16 + 100
        
        // Reset all timers
        SignalJammer.MGZ1.stateTimer = 0
        SignalJammer.MGZ1.stateRepeat = 0
        
        // Move to state 1 after a short delay
        if (SignalJammer.MGZ1.stateTimer > 60)
        {
            SignalJammer.MGZ1.state = 1
        }
    }
}

function void SignalJammer.MGZ1.DetailedState_1()
{
    // Movement and dodging logic
    // The boss moves in a pattern to avoid player attacks while spawning drones
    if (SignalJammer.MGZ1.state == 1)
    {
        // Horizontal movement
        if (SignalJammer.MGZ1.flipFlag)
            objA0.velocity.x = 0x200
        else
            objA0.velocity.x = -0x200
            
        // Vertical movement (sine wave)
        s32 angle = (global.framecounter * 2) % 360
        objA0.velocity.y = lookupSine(angle) / 8
        
        // Check boundaries
        if (objA0.position.x.u16 > camera.position.x.u16 + getScreenWidth() - 50)
            SignalJammer.MGZ1.flipFlag = false
        else if (objA0.position.x.u16 < camera.position.x.u16 + 50)
            SignalJammer.MGZ1.flipFlag = true
    }
}

function void SignalJammer.MGZ1.DetailedState_2()
{
    // Attack preparation logic
    // The boss stops moving and starts flashing/charging
    if (SignalJammer.MGZ1.state == 2)
    {
        objA0.velocity.x = 0
        objA0.velocity.y = 0
        
        // Visual feedback for charging
        if (global.framecounter % 4 < 2)
            TennaS.FlashAlpha = 0xff
        else
            TennaS.FlashAlpha = 0
    }
}

function void SignalJammer.MGZ1.DetailedState_3()
{
    // Active attack logic
    // The boss performs its primary attack (e.g., signal blast or drone swarm)
    if (SignalJammer.MGZ1.state == 3)
    {
        // Perform attack based on health or random choice
        if (boss.remaining_hits > 4)
            SignalJammer.MGZ1.SpecialAttack_SignalBlast()
        else
            SignalJammer.MGZ1.SpecialAttack_DroneSwarm()
    }
}

function void SignalJammer.MGZ1.DetailedState_4()
{
    // Recovery logic
    // The boss moves back to a safe position after an attack
    if (SignalJammer.MGZ1.state == 4)
    {
        s16 targetX = camera.position.x.u16 + getScreenWidth() / 2
        s16 targetY = camera.position.y.u16 + 50
        
        if (objA0.position.x.u16 < targetX)
            objA0.velocity.x = 0x300
        else
            objA0.velocity.x = -0x300
            
        if (objA0.position.y.u16 < targetY)
            objA0.velocity.y = 0x300
        else
            objA0.velocity.y = -0x300
    }
}

function void SignalJammer.MGZ1.DetailedState_5()
{
    // Defeat logic
    // The boss explodes and triggers the end of the fight
    if (SignalJammer.MGZ1.state == 5)
    {
        SignalJammer.MGZ1.ExplosionSequence()
    }
}

function void SignalJammer.MGZ1.DetailedState_6()
{
    // Phase transition logic
    // The boss changes its behavior for the second half of the fight
    if (SignalJammer.MGZ1.state == 6)
    {
        SignalJammer.MGZ1.PhaseTwoLogic()
    }
}

